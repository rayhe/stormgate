rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read any user doc, write only their own
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Characters: owner can read/write, others can read (for 'who' list, etc.)
    match /characters/{charId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if request.auth.uid == resource.data.ownerId
                            || getUserRole(request.auth.uid) in ['immortal', 'admin'];
    }

    // Areas: readable by all authenticated, writable by builders/immortals/admins
    match /areas/{areaId} {
      allow read: if request.auth != null;
      allow write: if getUserRole(request.auth.uid) in ['builder', 'immortal', 'admin'];

      match /rooms/{roomId} {
        allow read: if request.auth != null;
        allow write: if getUserRole(request.auth.uid) in ['builder', 'immortal', 'admin'];
      }
    }

    // Mob and object templates: readable by all, writable by builders+
    match /mob_templates/{vnum} {
      allow read: if request.auth != null;
      allow write: if getUserRole(request.auth.uid) in ['builder', 'immortal', 'admin'];
    }
    match /obj_templates/{vnum} {
      allow read: if request.auth != null;
      allow write: if getUserRole(request.auth.uid) in ['builder', 'immortal', 'admin'];
    }

    // World state: readable by all, writable only by server (admin SDK bypasses rules)
    match /world_state/{doc=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Clans and religions: readable by all, writable by immortals+
    match /clans/{clanId} {
      allow read: if request.auth != null;
      allow write: if getUserRole(request.auth.uid) in ['immortal', 'admin'];
    }
    match /religions/{relId} {
      allow read: if request.auth != null;
      allow write: if getUserRole(request.auth.uid) in ['immortal', 'admin'];
    }

    // Notes/boards: readable by all, writable by authenticated users
    match /notes/{noteId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth.uid == resource.data.senderUid
                            || getUserRole(request.auth.uid) in ['immortal', 'admin'];
    }

    function getUserRole(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }
  }
}
